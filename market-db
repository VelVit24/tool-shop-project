create table Users(
id serial primary key,
email text,
password text
);
create table Categories(
id serial primary key,
name text
);
create table Instruments(
id serial primary key,
name text,
category int references Categories(id)
);
create table Orders(
id serial primary key,
id_user int references Users(id),
description text
);
create table CartItems(
id_user int references Users(id),
id_instr int references Instruments(id),
amount int
);

